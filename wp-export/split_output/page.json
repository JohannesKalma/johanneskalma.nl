  {
    "title": "cheat sheet",
    "link": "https://johanneskalma.nl/cheat-sheet/",
    "pubDate": "Tue, 20 Aug 2019 20:24:36 +0000",
    "dc:creator": "knilluz",
    "guid": {
      "#text": "https://johanneskalma.nl/?page_id=702",
      "@_isPermaLink": "false"
    },
    "description": "",
    "content:encoded": "<!-- wp:paragraph -->\n<p>Postfix Mailqueue</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:code -->\n<pre class=\"wp-block-code\"><code>$sudo mailq</code></pre>\n<!-- /wp:code -->\n\n<!-- wp:paragraph -->\n<p>Delete from postfix mailqueue</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:code -->\n<pre class=\"wp-block-code\"><code>$sudo postsuper -d [identifier]</code></pre>\n<!-- /wp:code -->\n\n<!-- wp:paragraph -->\n<p>Read Buffer</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:code -->\n<pre class=\"wp-block-code\"><code>$sudo postcat -vq [identifier]</code></pre>\n<!-- /wp:code -->\n\n<!-- wp:paragraph -->\n<p>Purge <a href=\"https://johanneskalma.nl/packages-marked-as-rc-dpkg-l/\">packages marked as rc (dpkg -l)</a></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:code -->\n<pre class=\"wp-block-code\"><code>$dpkg -l | grep \"^rc\" | cut -d \" \" -f 3 | xargs sudo dpkg --purge</code></pre>\n<!-- /wp:code -->\n\n<!-- wp:paragraph -->\n<p>bunch of jpg’s into animation movie</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:code -->\n<pre class=\"wp-block-code\"><code>ffmpeg -framerate 6 -start_number 1763 -i IMG_%04d.JPG -r 24 -c:v libx264 -crf 20 -pix_fmt yuv420p -vf scale=1920:1080 test-3-6fps-24fps.mp4</code></pre>\n<!-- /wp:code -->\n\n<!-- wp:core-embed/youtube {\"url\":\"https://youtu.be/BSoVys8K0KY\",\"type\":\"video\",\"providerNameSlug\":\"youtube\",\"className\":\"wp-embed-aspect-16-9 wp-has-aspect-ratio\"} -->\n<figure class=\"wp-block-embed-youtube wp-block-embed is-type-video is-provider-youtube wp-embed-aspect-16-9 wp-has-aspect-ratio\"><div class=\"wp-block-embed__wrapper\">\nhttps://youtu.be/BSoVys8K0KY\n</div></figure>\n<!-- /wp:core-embed/youtube -->\n\n<!-- wp:paragraph -->\n<p></p>\n<!-- /wp:paragraph -->",
    "excerpt:encoded": "",
    "wp:post_id": 702,
    "wp:post_date": "2019-08-20 21:24:36",
    "wp:post_date_gmt": "2019-08-20 20:24:36",
