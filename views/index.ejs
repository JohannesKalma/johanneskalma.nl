<%- include('partials/header') %>

    <main class="site-main container">
        <section class="site-content">
            <% posts?.forEach(item=> { %>
                <article class="post">
                    <h2 class="post-title">
                        <a href="/<%= item.post_name %>">
                            <%= item.title %>
                        </a>
                    </h2>
                    <div class="post-meta">
                        <span class="author">By <%= item.author %></span>
                        <time>on <%= item.post_date %></time>
                    </div>
                    <p><%- item.content %></p>
                </article>
                <% }) %>
        </section>
    </main>

    <nav class="pagination container">

        <% if (pagination.prevPageUrl && pagination.prevPageUrl !=="" ) { %>
            <a href="<%= pagination.prevPageUrl %>" class="pagination-left">Newer posts</a>
        <% } else { %>
            <span class="pagination-left">&nbsp;</span>
        <% } %>

        <span class="pagination-center">
            Page <%= pagination.currentPage %> of <%= pagination.totalPages %>
        </span>

        <% if (pagination.nextPageUrl && pagination.nextPageUrl !=="" ) { %>
            <a href="<%= pagination.nextPageUrl %>" class="pagination-right">Older posts</a>
        <% } else { %>
            <span class="pagination-right">&nbsp;</span>
        <% } %>

    </nav>    

    <%- include('partials/footer') %>