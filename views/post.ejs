<%- include('partials/header') %>

    <main class="site-main container">
        <section class="site-content">
            <article class="post">
                <h2 class="post-title">
                    <a href="/<%= post.post_name %>">
                        <%= post.title %>
                    </a>
                </h2>
                <div class="post-meta">
                    <span class="author">By <%= post.author %></span>
                    <time>on <%= post.post_date %></time>
                </div>
                <p><%- post.content %></p>
            </article>
        </section>
    </main>

    <nav class="post-navigation container">
        <% if (post.previousPost) { %>
            <a href="/<%= post.previousPost.post_name %>" class="nav-previous">
                <%= post.previousPost.title %>
            </a>
            <% } %>
                <% if (post.nextPost) { %>
                    <a href="/<%= post.nextPost.post_name %>" class="nav-next">
                        <%= post.nextPost.title %>
                    </a>
                    <% } %>
    </nav>

    <%- include('partials/footer') %>